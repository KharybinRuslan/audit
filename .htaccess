# Аудит — локальный сайт http://aud/
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # /pages/name.php → /name (301); THE_REQUEST — только реальный запрос, не внутренняя подстановка
    RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /pages/[^?\s]+\.php(\?|\s) [NC]
    RewriteRule ^pages/([^/.]+)\.php$ /$1 [R=301,L,QSA]

    # Чистые URL: /name → pages/name.php (если файл есть)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{DOCUMENT_ROOT}/pages/$1.php -f
    RewriteRule ^([^/.]+)/?$ pages/$1.php [L,QSA]

    # Главная: не файл/не каталог
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^$ index.php [L]
</IfModule>

# Главная страница по умолчанию
DirectoryIndex index.php

# Кодировка по умолчанию
AddDefaultCharset UTF-8

# Разрешить доступ к шрифтам и статике
<FilesMatch "\.(ttf|otf|woff|woff2|css|js|png|jpg|jpeg|gif|ico|svg)$">
    <IfModule mod_headers.c>
        Header set Access-Control-Allow-Origin "*"
    </IfModule>
</FilesMatch>
